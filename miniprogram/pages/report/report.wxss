.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.report-container {
  padding: 40rpx 32rpx;
}

.report-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  text-align: center;
  margin-bottom: 40rpx;
}

.stats {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.stat-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #3b82f6;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.tag-focus {
  background: #fef3c7;
  color: #92400e;
}

.tag-error {
  background: #fee2e2;
  color: #991b1b;
}

.tag-good {
  background: #d1fae5;
  color: #065f46;
}

.summary-text {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.8;
  white-space: pre-wrap;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 48rpx;
  padding-bottom: 60rpx;
}

.act-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.act-btn.primary {
  background: #3b82f6;
  color: #fff;
}

.act-btn.secondary {
  background: #f3f4f6;
  color: #6b7280;
}
