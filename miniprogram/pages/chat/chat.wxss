.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
  overflow: hidden;
}

.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  height: 0;
}

/* ---- Chat scroll area ---- */

.chat-area {
  flex: 1;
  height: 0;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.message-list {
  display: flex;
  flex-direction: column;
}

.empty-chat {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200rpx;
}

.empty-text {
  color: #9ca3af;
  font-size: 28rpx;
}

/* ---- Live thinking ---- */

.live-thinking {
  padding: 16rpx 0;
}

.loading-spinner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 12rpx 0;
}

.spinner-icon {
  display: inline-block;
  animation: spin 1s linear infinite;
  font-size: 28rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.spinner-text {
  font-size: 26rpx;
  color: #9ca3af;
}

/* ---- Bottom area ---- */

.bottom-area {
  flex-shrink: 0;
  background: #fff;
  border-top: 1rpx solid #e5e7eb;
}

.input-row {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  align-items: center;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.text-input {
  flex: 1;
  height: 76rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 38rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  background: #f9fafb;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.text-input.disabled {
  color: #9ca3af;
  justify-content: center;
  font-size: 26rpx;
}

.send-btn {
  width: 120rpx;
  height: 76rpx;
  border-radius: 38rpx;
  background: #3b82f6;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn[disabled] {
  background: #93c5fd;
  color: rgba(255,255,255,0.7);
}

.loading-hint {
  padding: 20rpx 32rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 26rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

/* ---- Error ---- */

.error-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 24rpx;
  background: #fef2f2;
  border-top: 1rpx solid #fecaca;
}

.error-text {
  flex: 1;
  font-size: 24rpx;
  color: #dc2626;
}

.retry-btn {
  padding: 8rpx 24rpx;
  height: auto;
  font-size: 24rpx;
  background: #dc2626;
  color: #fff;
  border-radius: 8rpx;
  border: none;
}

/* ---- Modal (confirm dialogs) ---- */

.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-card {
  background: #fff;
  border-radius: 20rpx;
  width: 560rpx;
  padding: 48rpx 40rpx 32rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-body {
  font-size: 28rpx;
  color: #6b7280;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel { background: #f3f4f6; color: #6b7280; }
.modal-btn.confirm { background: #3b82f6; color: #fff; }
