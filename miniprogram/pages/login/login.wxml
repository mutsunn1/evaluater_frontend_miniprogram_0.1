<!-- Login page — matches the mobile Web look: light blue bg, centered white card -->
<view class="container">
  <view
    class="page-lang-switch"
    bind:tap="onSwitchLocale"
    data-locale="{{locale === 'en' ? 'zh' : 'en'}}"
    data-testid="language-switcher"
  >
    {{locale === 'en' ? i18n.langZh : i18n.langEn}}
  </view>

  <view class="card">
    <view class="title">{{i18n.appTitleFull}}</view>
    <view class="subtitle">{{i18n.userId}}</view>

    <input
      class="input"
      type="text"
      placeholder="{{i18n.userIdPlaceholder}}"
      value="{{inputId}}"
      bind:input="onInputChange"
      disabled="{{loading}}"
      maxlength="50"
    />

    <button
      class="start-btn"
      disabled="{{!inputId || loading}}"
      bind:tap="handleStart"
      loading="{{loading}}"
    >
      {{loading ? i18n.loggingIn : i18n.startEvaluation}}
    </button>

    <view class="error" wx:if="{{errorDisplay}}">{{errorDisplay}}</view>
  </view>
</view>
