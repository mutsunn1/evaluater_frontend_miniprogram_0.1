.container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #e0e7ff 0%, #dbeafe 50%, #eff6ff 100%);
  padding: 40rpx;
}

.page-lang-switch {
  position: absolute;
  top: 120rpx;
  left: 40rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #4b5563;
  background: #fff;
  border-radius: 9999rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #e5e7eb;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  width: 100%;
  max-width: 600rpx;
  box-shadow: 0 8rpx 32rpx rgba(59, 130, 246, 0.12);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e3a5f;
  text-align: center;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6b7280;
  text-align: center;
  margin-bottom: 48rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #1f2937;
  background: #f9fafb;
  box-sizing: border-box;
}

.input:focus {
  border-color: #3b82f6;
  background: #fff;
}

.start-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 32rpx;
  background: #3b82f6;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.start-btn[disabled] {
  background: #93c5fd;
  color: rgba(255, 255, 255, 0.8);
}

.error {
  margin-top: 24rpx;
  color: #dc2626;
  font-size: 26rpx;
  text-align: center;
}
