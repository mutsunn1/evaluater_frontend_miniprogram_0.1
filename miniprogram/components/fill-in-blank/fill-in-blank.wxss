.fib {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.blanks {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.blank-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.blank-label {
  font-size: 26rpx;
  color: #6b7280;
  width: 80rpx;
}

.blank-input {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 10rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  background: #fff;
  box-sizing: border-box;
}

.blank-input:focus {
  border-color: #3b82f6;
}

.blank-input.single {
  flex: none;
  width: 100%;
}

.confirm-btn {
  margin-top: 12rpx;
  height: 76rpx;
  background: #3b82f6;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 14rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
