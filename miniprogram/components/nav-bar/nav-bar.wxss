.nav-bar {
  background: #fff;
  border-bottom: 1rpx solid #e5e7eb;
}

.capsule-space {
  width: 100%;
}

.business-bar {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) auto;
  align-items: center;
  column-gap: 14rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.profile-btn {
  width: 72rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  height: 64rpx;
  padding: 0;
  margin: 0;
  border-radius: 16rpx;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 1;
  box-sizing: border-box;
  justify-self: start;
}

.profile-close {
  font-size: 36rpx;
  color: #4b5563;
  line-height: 1;
}

.profile-symbol {
  position: relative;
  width: 38rpx;
  height: 40rpx;
}

.person-head {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 16rpx;
  border: 4rpx solid #4b5563;
  border-radius: 50%;
}

.person-body {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: 18rpx;
  border: 4rpx solid #4b5563;
  border-bottom: none;
  border-radius: 20rpx 20rpx 0 0;
}

.title-group {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  overflow: hidden;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.user-badge {
  background: #eff6ff;
  min-width: 46rpx;
  height: 46rpx;
  padding: 0 14rpx;
  border-radius: 23rpx;
  line-height: 46rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #3b82f6;
  max-width: 110rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.action-btn {
  width: 120rpx;
  min-width: 0;
  height: 64rpx;
  padding: 0;
  margin: 0;
  border-radius: 14rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
  box-sizing: border-box;
}

.action-btn.end {
  width: 156rpx;
  background: #dc2626;
  color: #fff;
}

.action-btn.exit {
  width: 100rpx;
  background: #f3f4f6;
  color: #374151;
}

@media (max-width: 370px) {
  .business-bar {
    grid-template-columns: 64rpx minmax(0, 1fr) auto;
    column-gap: 10rpx;
    padding: 0 18rpx;
  }

  .profile-btn {
    width: 64rpx;
    min-width: 64rpx;
    max-width: 64rpx;
    height: 60rpx;
  }

  .nav-title {
    font-size: 30rpx;
  }

  .action-btn {
    height: 60rpx;
    font-size: 26rpx;
  }

  .action-btn.end {
    width: 112rpx;
  }

  .action-btn.exit {
    width: 88rpx;
  }
}
