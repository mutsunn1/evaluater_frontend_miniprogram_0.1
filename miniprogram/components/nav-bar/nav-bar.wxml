<!-- Custom nav: reserve the native capsule area, then render the product bar below it. -->
<view class="nav-bar">
  <view class="capsule-space" style="height: {{layout.businessBarTop}}px;"></view>
  <view class="business-bar" style="height: {{layout.businessBarHeight}}px;">
    <view class="profile-btn" bind:tap="onProfileTap" role="button" aria-label="{{i18n.openProfile}}">
      <text class="profile-close" wx:if="{{profileOpen}}">×</text>
      <view class="profile-symbol" wx:else>
        <view class="person-head"></view>
        <view class="person-body"></view>
      </view>
    </view>

    <view class="title-group">
      <text class="nav-title">{{i18n.appTitle}}</text>
      <text class="user-badge" wx:if="{{userId}}">{{userId}}</text>
    </view>

    <view class="nav-actions">
      <view
        class="action-btn lang"
        bind:tap="onLangTap"
        role="button"
        data-testid="language-switcher"
      >
        {{locale === 'en' ? i18n.langZh : i18n.langEn}}
      </view>
      <view class="action-btn end" bind:tap="onEndTap" role="button">{{i18n.endEvaluation}}</view>
      <view class="action-btn exit" bind:tap="onExitTap" role="button">{{i18n.logout}}</view>
    </view>
  </view>
</view>
