<!-- Inline thinking summaries — top 2 high-value steps -->
<view class="thinking-inline" wx:if="{{visibleSteps.length}}">
  <view
    wx:for="{{visibleSteps}}"
    wx:key="_key"
    class="step-summary"
    bind:tap="onTapStep"
    data-index="{{item._origIndex}}"
  >
    <text class="step-icon">💡</text>
    <text class="step-agent">{{item.agent}}</text>
    <text class="step-preview">{{item.preview}}</text>
  </view>
  <view class="expand-hint" wx:if="{{allCount > visibleSteps.length}}" bind:tap="onExpandAll">
    <text>查看全部 {{allCount}} 条思考过程</text>
  </view>
</view>
