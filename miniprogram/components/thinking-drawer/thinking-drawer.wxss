/* Backdrop */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 200;
  pointer-events: none;
  transition: background 0.25s;
}

.drawer-mask.visible {
  background: rgba(0, 0, 0, 0.4);
  pointer-events: auto;
}

/* Panel slides from right */
.drawer-panel {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: 640rpx;
  max-width: 85vw;
  background: #fff;
  z-index: 201;
  transform: translateX(100%);
  transition: transform 0.25s ease;
  display: flex;
  flex-direction: column;
}

.drawer-panel.open {
  transform: translateX(0);
}

/* Header */
.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #e5e7eb;
  flex-shrink: 0;
  padding-top: calc(28rpx + env(safe-area-inset-top));
}

.drawer-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

.drawer-close {
  font-size: 36rpx;
  color: #9ca3af;
  padding: 8rpx;
}

/* Body */
.drawer-body {
  flex: 1;
  padding: 20rpx 24rpx;
}

.step-card {
  background: #f9fafb;
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid #3b82f6;
}

.step-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.step-bulb {
  font-size: 28rpx;
}

.step-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.step-output {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.8;
  white-space: pre-wrap;
}

.empty {
  text-align: center;
  color: #9ca3af;
  font-size: 28rpx;
  padding: 80rpx 0;
}
