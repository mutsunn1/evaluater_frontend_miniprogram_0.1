<!-- Right slide-in full thinking drawer -->
<view class="drawer-mask {{open ? 'visible' : ''}}" bind:tap="onClose" catchtouchmove>
  <view class="drawer-panel {{open ? 'open' : ''}}" catchtap>
    <view class="drawer-header">
      <text class="drawer-title">思考过程</text>
      <text class="drawer-close" bind:tap="onClose">✕</text>
    </view>

    <scroll-view class="drawer-body" scroll-y enhanced>
      <view class="step-card" wx:for="{{drawerSteps}}" wx:key="_key">
        <view class="step-head">
          <text class="step-bulb">💡</text>
          <text class="step-name">{{item.agent}}</text>
        </view>
        <text class="step-output">{{item.output}}</text>
      </view>
      <view class="empty" wx:if="{{!drawerSteps.length}}">
        <text>暂无思考过程</text>
      </view>
    </scroll-view>
  </view>
</view>
