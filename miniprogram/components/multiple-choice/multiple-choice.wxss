.mc {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.option {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 22rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 14rpx;
  background: #fff;
  transition: all 0.15s;
}

.option.selected {
  border-color: #3b82f6;
  background: #eff6ff;
}

.opt-letter {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option.selected .opt-letter {
  background: #3b82f6;
  color: #fff;
}

.opt-text {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.5;
}

.opt-check {
  font-size: 28rpx;
  color: #3b82f6;
  font-weight: 700;
}

.confirm-btn {
  margin-top: 16rpx;
  height: 76rpx;
  background: #3b82f6;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 14rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
