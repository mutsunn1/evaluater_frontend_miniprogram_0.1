<!-- Speech recorder — record, play, delete, upload, review transcript -->
<view class="sp-rec">
  <!-- Idle -->
  <view wx:if="{{state === 'idle'}}" class="sp-idle">
    <text class="sp-hint">{{i18n.hint}}</text>
    <button class="sp-record-btn" bind:tap="startRecording" data-testid="speech-record-btn">
      🎙️ {{i18n.start}}
    </button>
  </view>

  <!-- Recording -->
  <view wx:elif="{{state === 'recording'}}" class="sp-recording">
    <view class="sp-rec-header">
      <text class="sp-rec-dot">🔴</text>
      <text class="sp-rec-label">{{i18n.recording}}</text>
      <text class="sp-elapsed">{{elapsedDisplay}}</text>
    </view>
    <progress percent="{{progressPct}}" activeColor="#ef4444" stroke-width="4" />
    <button class="sp-stop-btn" bind:tap="stopRecording" data-testid="speech-stop-btn">
      ⏹ {{i18n.stop}}
    </button>
  </view>

  <!-- Recorded -->
  <view wx:elif="{{state === 'recorded'}}" class="sp-done">
    <text class="sp-done-label">{{i18n.recorded}} · {{elapsedDisplay}}</text>
    <view class="sp-done-actions">
      <button class="sp-play-btn" bind:tap="playRecording" wx:if="{{!isPlaying}}">▶ {{i18n.play}}</button>
      <button class="sp-pause-btn" bind:tap="stopPlayback" wx:else>⏸ {{i18n.pause}}</button>
      <button class="sp-upload-btn" bind:tap="uploadRecording" data-testid="speech-upload-btn">{{i18n.upload}}</button>
      <button class="sp-delete-btn" bind:tap="deleteRecording">🗑 {{i18n.reRecord}}</button>
    </view>
  </view>

  <!-- Transcribed -->
  <view wx:elif="{{state === 'transcribed'}}" class="sp-trans">
    <text class="sp-trans-label">{{i18n.transcriptTitle}}</text>
    <view class="sp-trans-box"><text>{{transcript}}</text></view>
    <view class="sp-trans-actions">
      <button class="sp-delete-btn" bind:tap="deleteRecording">{{i18n.reRecord}}</button>
      <button class="sp-confirm-btn" bind:tap="confirmTranscript">{{i18n.confirm}}</button>
    </view>
  </view>

  <!-- Failed -->
  <view wx:elif="{{state === 'failed'}}" class="sp-fail">
    <text class="sp-fail-msg">{{error || i18n.transcribeFailed}}</text>
    <button class="sp-delete-btn" bind:tap="deleteRecording">{{i18n.reRecord}}</button>
  </view>
</view>
