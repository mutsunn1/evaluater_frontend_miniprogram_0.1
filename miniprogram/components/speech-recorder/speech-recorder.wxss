.sp-rec {
  padding: 16px 0;
}
.sp-idle {
  text-align: center;
}
.sp-hint {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 12px;
}
.sp-record-btn {
  background: #ef4444;
  color: #fff;
  border-radius: 8px;
  font-size: 14px;
}
.sp-recording {
}
.sp-rec-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}
.sp-rec-dot {
}
.sp-rec-label {
  color: #ef4444;
  font-weight: 600;
  font-size: 14px;
}
.sp-elapsed {
  color: #999;
  font-size: 13px;
  margin-left: auto;
}
.sp-stop-btn {
  background: #374151;
  color: #fff;
  border-radius: 8px;
  margin-top: 12px;
  font-size: 14px;
}
.sp-done {
}
.sp-done-label {
  display: block;
  font-size: 14px;
  color: #374151;
  margin-bottom: 12px;
}
.sp-done-actions {
  display: flex;
  gap: 8px;
}
.sp-play-btn,
.sp-pause-btn,
.sp-upload-btn {
  flex: 1;
  background: #3b82f6;
  color: #fff;
  border-radius: 8px;
  font-size: 14px;
}
.sp-upload-btn {
  background: #22c55e;
}
.sp-delete-btn {
  background: none;
  border: 1rpx solid #fca5a5;
  color: #ef4444;
  border-radius: 8px;
  font-size: 14px;
}
.sp-trans {
}
.sp-trans-label {
  display: block;
  font-size: 12px;
  color: #999;
  margin-bottom: 8px;
}
.sp-trans-box {
  background: #f9fafb;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}
.sp-trans-box text {
  font-size: 14px;
  color: #374151;
  line-height: 1.5;
}
.sp-trans-actions {
  display: flex;
  gap: 8px;
}
.sp-confirm-btn {
  flex: 1;
  background: #22c55e;
  color: #fff;
  border-radius: 8px;
  font-size: 14px;
}
.sp-fail {
  text-align: center;
}
.sp-fail-msg {
  display: block;
  font-size: 14px;
  color: #ef4444;
  margin-bottom: 12px;
}
