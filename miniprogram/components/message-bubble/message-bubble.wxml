<!-- Chat message bubble — uses unified question-renderer for both batch and single -->
<view class="wrapper wrapper-{{message.role}}">
  <!-- Thinking steps before question messages -->
  <thinking-process
    wx:if="{{message.role === 'question' && message.thinking_steps && message.thinking_steps.length}}"
    steps="{{message.thinking_steps}}"
    bind:open="onOpenThinking"
  />

  <view class="bubble bubble-{{message.role}}">
    <!-- System / cold_start text -->
    <text wx:if="{{isTextRole}}" class="bubble-text">{{message.content}}</text>

    <!-- User text -->
    <text wx:if="{{message.role === 'user'}}" class="bubble-text">{{message.content}}</text>

    <!-- Feedback -->
    <view wx:elif="{{message.role === 'feedback'}}" class="feedback-wrap">
      <text class="bubble-text">{{message.content}}</text>
      <view class="dimension-badge" wx:if="{{message.item_data && message.item_data.skill_dimension}}">
        {{message.item_data.skill_dimension}}
      </view>
    </view>

    <!-- Single question: unified renderer -->
    <view wx:if="{{message.role === 'question' && message.item_data}}" class="single-question">
      <view wx:for="{{message.item_data.media}}" wx:key="id" wx:if="{{item.role === 'prompt'}}">
        <media-prompt-block asset="{{item}}" />
      </view>
      <question-renderer
        itemData="{{message.item_data}}"
        bind:answer="onSingleAnswer"
      />
    </view>

    <!-- Batch questions: unified renderer per question -->
    <view wx:if="{{message.role === 'question' && message.batch_questions && message.batch_questions.length}}" class="batch-questions">
      <view wx:for="{{message.batch_questions}}" wx:for-item="q" wx:for-index="qi" wx:key="batch_index" class="batch-item">
        <view class="batch-q-header">
          <text class="batch-q-num">{{q.batch_index !== undefined ? q.batch_index + 1 : qi + 1}}.</text>
          <text class="batch-q-type" wx:if="{{q.skill_dimension}}">{{q.skill_dimension}}</text>
        </view>

        <!-- Prompt media for this batch item -->
        <view wx:for="{{q.media}}" wx:for-item="m" wx:key="id" wx:if="{{m.role === 'prompt'}}">
          <media-prompt-block asset="{{m}}" />
        </view>

        <!-- Response dispatch by mode -->
        <block wx:if="{{itemModes[qi] === 'choice'}}">
          <question-renderer
            itemData="{{q}}"
            data-qidx="{{qi}}"
            bind:answer="onBatchQuestionAnswer"
          />
        </block>

        <block wx:elif="{{itemModes[qi] === 'text'}}">
          <question-renderer
            itemData="{{q}}"
            data-qidx="{{qi}}"
            bind:answer="onBatchQuestionAnswer"
          />
        </block>

        <speech-response-placeholder wx:elif="{{itemModes[qi] === 'speech'}}" />
        <handwriting-response-placeholder wx:elif="{{itemModes[qi] === 'handwriting'}}" />
        <upload-response-placeholder wx:elif="{{itemModes[qi] === 'upload'}}" />
        <text wx:else class="qr-fallback">未知响应模式: {{itemModes[qi]}}</text>
      </view>

      <button class="batch-submit" disabled="{{!canBatchSubmit}}" bind:tap="onBatchSubmit">
        提交全部答案
      </button>
    </view>
  </view>

  <text class="time" wx:if="{{showTime}}">{{formattedTime}}</text>

  <thinking-process
    wx:if="{{message.role !== 'question' && message.thinking_steps && message.thinking_steps.length}}"
    steps="{{message.thinking_steps}}"
    bind:open="onOpenThinking"
  />
</view>
