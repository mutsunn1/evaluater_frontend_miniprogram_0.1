.wrapper {
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
  max-width: 86%;
}

.wrapper-system,
.wrapper-cold_start {
  align-self: center;
  max-width: 92%;
}

.wrapper-user {
  align-self: flex-end;
}
.wrapper-question,
.wrapper-feedback {
  align-self: flex-start;
}

/* Bubble shapes */

.bubble {
  padding: 20rpx 28rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-word;
}

.bubble-system {
  background: #e5e7eb;
  color: #6b7280;
  text-align: center;
}
.bubble-user {
  background: #3b82f6;
  color: #fff;
  border-bottom-right-radius: 6rpx;
}
.bubble-question {
  background: #fff;
  border: 2rpx solid #e5e7eb;
  color: #1f2937;
  border-top-left-radius: 6rpx;
}
.bubble-feedback {
  background: #f0fdf4;
  border: 2rpx solid #bbf7d0;
  color: #166534;
}
.bubble-cold_start {
  background: #eef2ff;
  color: #3730a3;
  text-align: center;
}

.bubble-text {
  white-space: pre-wrap;
}

/* Feedback */

.feedback-wrap {
  display: flex;
  flex-direction: column;
}

.dimension-badge {
  margin-top: 12rpx;
  display: inline-block;
  align-self: flex-start;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #d1fae5;
  color: #065f46;
}

/* Timestamp */

.time {
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 6rpx;
}

.wrapper-user .time {
  text-align: right;
}

/* Batch questions */

.batch-questions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.batch-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.batch-q-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.batch-q-num {
  font-weight: 600;
  color: #3b82f6;
  font-size: 28rpx;
}

.batch-q-type {
  font-size: 22rpx;
  color: #9ca3af;
  text-transform: capitalize;
}

.batch-submit {
  width: 100%;
  height: 76rpx;
  margin-top: 16rpx;
  background: #3b82f6;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.batch-submit-disabled {
  background: #93c5fd;
  color: rgba(255, 255, 255, 0.7);
}

.modality-question {
  display: block;
  margin-bottom: 12rpx;
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
}

.skip-modality {
  width: 100%;
  min-height: 72rpx;
  margin-top: 12rpx;
  border: 2rpx dashed #d1d5db;
  border-radius: 12rpx;
  background: #f9fafb;
  color: #4b5563;
  font-size: 26rpx;
  font-weight: 500;
}

.skip-modality-selected {
  border-style: solid;
  border-color: #6b7280;
  background: #f3f4f6;
  color: #1f2937;
}
