<!-- Reading comprehension — passage + sub-questions with inputs -->
<view class="rc">
  <!-- Passage -->
  <view class="passage" wx:if="{{passage}}">
    <text class="passage-label">{{i18n.readingPassage}}</text>
    <text class="passage-text">{{passage}}</text>
  </view>

  <!-- Main question text -->
  <text class="question-text" wx:if="{{questionText}}">{{questionText}}</text>

  <!-- Sub-questions -->
  <view class="sub-qs" wx:if="{{labeledSubQuestions.length}}">
    <view wx:for="{{labeledSubQuestions}}" wx:key="sub_id" class="sub-q">
      <text class="sub-q-text">{{item.label}} {{item.question_text}}</text>
      <input
        class="sub-q-input"
        placeholder="{{i18n.fillBlank}}"
        value="{{answers[item.sub_id] || ''}}"
        data-sid="{{item.sub_id}}"
        bind:input="onInput"
      />
    </view>
  </view>

  <!-- Fallback: single reading question without sub-questions -->
  <view class="main-answer" wx:else>
    <input
      class="main-answer-input"
      placeholder="{{i18n.fillBlank}}"
      value="{{mainAnswer}}"
      bind:input="onMainInput"
    />
  </view>

  <button class="confirm-btn" bind:tap="onConfirm" wx:if="{{canSubmit}}">
    {{i18n.confirm}}
  </button>
</view>
