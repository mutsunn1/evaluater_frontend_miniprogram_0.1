.rc {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.passage {
  background: #fffbeb;
  border: 2rpx solid #fde68a;
  border-radius: 14rpx;
  padding: 24rpx;
}

.passage-text {
  font-size: 28rpx;
  color: #78350f;
  line-height: 2;
  white-space: pre-wrap;
}

.question-text {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
  line-height: 1.7;
}

.sub-qs {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.sub-q {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.sub-q-text {
  font-size: 27rpx;
  color: #374151;
  line-height: 1.6;
}

.sub-q-input {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 10rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  background: #fff;
  box-sizing: border-box;
}

.main-answer {
  margin-top: 8rpx;
}

.main-answer-input {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 10rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  background: #fff;
  box-sizing: border-box;
}

.main-answer-input:focus {
  border-color: #3b82f6;
}

.sub-q-input:focus {
  border-color: #3b82f6;
}

.confirm-btn {
  margin-top: 8rpx;
  height: 76rpx;
  background: #3b82f6;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 14rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
