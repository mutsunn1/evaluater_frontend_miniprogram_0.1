<!-- Unified question renderer — dispatches to sub-components by type -->
<view class="qr">
  <!-- Meta tags: scene, grammar focus, target level -->
  <view class="qr-meta" wx:if="{{scene || grammarFocus || targetLevel}}">
    <text class="meta-tag" wx:if="{{scene}}">场景: {{scene}}</text>
    <text class="meta-tag" wx:if="{{grammarFocus}}">语法: {{grammarFocus}}</text>
    <text class="meta-tag" wx:if="{{targetLevel}}">{{targetLevel}}</text>
  </view>

  <!-- Question text -->
  <text class="qr-text" wx:if="{{questionText && qType !== 'reading_comprehension'}}">{{questionText}}</text>

  <!-- Dispatch by type -->
  <multiple-choice
    wx:if="{{qType === 'multiple_choice' || qType === 'multiple_select' || qType === 'listening_comprehension'}}"
    options="{{options}}"
    media="{{media}}"
    multiSelect="{{qType === 'multiple_select'}}"
    bind:answer="onAnswer"
  />

  <true-false
    wx:elif="{{qType === 'true_false'}}"
    bind:answer="onAnswer"
  />

  <fill-in-blank
    wx:elif="{{qType === 'fill_in_blank'}}"
    blankCount="{{blankCount}}"
    bind:answer="onAnswer"
  />

  <reading-comprehension
    wx:elif="{{qType === 'reading_comprehension'}}"
    passage="{{readingPassage}}"
    questionText="{{questionText}}"
    subQuestions="{{subQuestions}}"
    bind:answer="onAnswer"
  />

  <!-- speaking_response: prompt media only. The speech recorder + skip
       option live in message-bubble.wxml (batch path), where sessionId and
       questionItemId are available. Rendering <speech-recorder /> here
       previously mounted it with no props and no answer binding, so the
       asset_id never propagated. -->
  <block wx:elif="{{qType === 'speaking_response' || qType === 'speaking'}}">
    <view wx:for="{{media}}" wx:key="id" wx:if="{{item.role === 'prompt' || item.role === 'question' || item.role === 'stimulus'}}">
      <media-prompt-block asset="{{item}}" />
    </view>
  </block>

  <!-- Fallback: plain text for unknown types -->
  <text wx:else class="qr-fallback">不支持的问题类型: {{qType}}</text>
</view>
