.bar {
  background: #fff;
  border-top: 1rpx solid #e5e7eb;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.bar-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

/* ---- Progress ---- */

.progress-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.progress-bg {
  flex: 1;
  height: 14rpx;
  background: #f3f4f6;
  border-radius: 7rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 7rpx;
  transition: width 0.4s ease;
}

.progress-yellow { background: #f59e0b; }
.progress-green { background: #22c55e; }
.progress-blue { background: #3b82f6; }

.progress-text {
  font-size: 24rpx;
  color: #6b7280;
  min-width: 80rpx;
  text-align: right;
}

/* ---- Dimensions ---- */

.dim-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
}

.dim-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dim-dot.vocab { background: #22c55e; }
.dim-dot.grammar { background: #f59e0b; }
.dim-dot.reading { background: #a855f7; }

.dim-num {
  font-size: 22rpx;
  color: #374151;
  margin-right: 8rpx;
  min-width: 24rpx;
}

.dim-spacer {
  color: #d1d5db;
  font-size: 22rpx;
  margin: 0 4rpx;
}

.dim-label {
  font-size: 22rpx;
  color: #9ca3af;
}

.dim-val {
  font-size: 22rpx;
  color: #374151;
  font-weight: 600;
}

/* ---- Stop badge ---- */

.stop-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #16a34a;
  font-weight: 600;
  padding: 8rpx 0;
}

.stop-pulse {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #22c55e;
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
