<!-- Bottom confidence bar — progress, dimensions, accuracy, stop indicator -->
<view class="bar" wx:if="{{visible}}">
  <view class="bar-content">
    <!-- Progress -->
    <view class="progress-row">
      <view class="progress-bg">
        <view class="progress-fill {{progressColor}}" style="width: {{progressPct}}%;"></view>
      </view>
      <text class="progress-text">{{roundText}}</text>
    </view>

    <!-- Dimensions -->
    <view class="dim-row">
      <view class="dim-dot vocab"></view>
      <text class="dim-num">{{confidence.dimension_rounds ? confidence.dimension_rounds.vocabulary : 0}}{{i18n.roundUnit}}</text>
      <view class="dim-dot grammar"></view>
      <text class="dim-num">{{confidence.dimension_rounds ? confidence.dimension_rounds.grammar : 0}}{{i18n.roundUnit}}</text>
      <view class="dim-dot reading"></view>
      <text class="dim-num">{{confidence.dimension_rounds ? confidence.dimension_rounds.reading : 0}}{{i18n.roundUnit}}</text>
      <view class="dim-dot listening"></view>
      <text class="dim-num">{{confidence.dimension_rounds ? confidence.dimension_rounds.listening : 0}}{{i18n.roundUnit}}</text>
      <view class="dim-dot speaking"></view>
      <text class="dim-num">{{confidence.dimension_rounds ? confidence.dimension_rounds.speaking : 0}}{{i18n.roundUnit}}</text>
      <text class="dim-spacer">|</text>
      <text class="dim-label">{{i18n.accuracy}}</text>
      <text class="dim-val">{{accuracyPct}}%</text>
      <text class="dim-spacer">|</text>
      <text class="dim-label">{{i18n.confidence}}</text>
      <text class="dim-val">{{confidencePct}}%</text>
    </view>

    <!-- Auto-stop indicator -->
    <view class="stop-badge" wx:if="{{confidence.should_stop}}">
      <text class="stop-pulse"></text>
      <text>{{i18n.complete}}</text>
    </view>
  </view>
</view>
