.drawer {
  width: 100%;
  background: #1e293b;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.drawer.open {
  max-height: 360rpx;
  overflow-y: auto;
}

.content {
  padding: 26rpx 32rpx 30rpx;
}

.error {
  padding: 32rpx;
  color: #fca5a5;
  font-size: 26rpx;
  text-align: center;
}

.level-badge {
  display: flex;
  align-items: baseline;
  gap: 22rpx;
  margin-bottom: 22rpx;
}

.level-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #60a5fa;
}

.level-label {
  font-size: 24rpx;
  color: #94a3b8;
}

.skill-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  column-gap: 34rpx;
  row-gap: 18rpx;
  margin-bottom: 22rpx;
}

.skill-card {
  min-width: 0;
}

.skill-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.skill-name {
  font-size: 26rpx;
  color: #cbd5e1;
}

.skill-val {
  font-size: 24rpx;
  color: #cbd5e1;
  text-align: right;
}

.skill-bar-bg {
  height: 12rpx;
  background: #334155;
  border-radius: 6rpx;
  overflow: hidden;
}

.skill-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.skill-blue {
  background: #3b82f6;
}
.skill-purple {
  background: #a855f7;
}
.skill-green {
  background: #22c55e;
}
.skill-orange {
  background: #f97316;
}

.tags-section {
  margin-bottom: 16rpx;
}

.tag-label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
  display: block;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.tag-good {
  background: #064e3b;
  color: #6ee7b7;
}

.tag-focus {
  background: #78350f;
  color: #fcd34d;
}

.updated {
  display: block;
  font-size: 20rpx;
  color: #475569;
  margin-top: 16rpx;
}
