<!-- True/False — two large tappable buttons -->
<view class="tf">
  <view
    class="tf-btn true {{answer === 'true' ? 'active' : ''}}"
    bind:tap="onTap"
    data-val="true"
  >
    <text class="tf-icon">✓</text>
    <text class="tf-label">{{i18n.trueLabel}}</text>
  </view>
  <view
    class="tf-btn false {{answer === 'false' ? 'active' : ''}}"
    bind:tap="onTap"
    data-val="false"
  >
    <text class="tf-icon">✕</text>
    <text class="tf-label">{{i18n.falseLabel}}</text>
  </view>

  <button class="confirm-btn" bind:tap="onConfirm" wx:if="{{answer}}">
    {{i18n.confirm}}
  </button>
</view>
